{
  "contract": "fixed",
  "projectName": "",
  "paths": {
    "tasks": "harness/tasks.md",
    "status": "harness/status.md",
    "goals": "harness/goals",
    "runs": ".harness/runs"
  },
  "language": {
    "default": "auto"
  },
  "worktree": {
    "defaultPolicy": "ask",
    "autoRules": [
      {
        "when": "user_explicitly_requests_no_branch_or_worktree",
        "use": "local"
      },
      {
        "when": "local_checkout_has_unrelated_changes",
        "use": "worktree"
      },
      {
        "when": "parallel_or_unattended_work",
        "use": "worktree"
      },
      {
        "when": "destructive_or_production_action",
        "use": "ask"
      }
    ]
  },
  "loops": {
    "defaultMode": "report-only",
    "maxIterations": 3,
    "requiresVerification": true
  }
}
