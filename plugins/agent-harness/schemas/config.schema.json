{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-harness.local/schemas/config.schema.json",
  "title": "Agent Harness Config",
  "type": "object",
  "anyOf": [
    {
      "required": [
        "contract"
      ]
    },
    {
      "required": [
        "mode"
      ]
    }
  ],
  "additionalProperties": false,
  "properties": {
    "contract": {
      "type": "string",
      "enum": [
        "fixed",
        "adapter"
      ]
    },
    "mode": {
      "description": "Legacy alias for contract; canonical output omits it and conflicts fail.",
      "type": "string",
      "enum": [
        "fixed",
        "adapter"
      ]
    },
    "projectName": {
      "type": "string"
    },
    "adapter": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "docs": {
          "type": "string",
          "minLength": 1
        },
        "machineReadable": {
          "type": "string",
          "minLength": 1
        },
        "preflight": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "stateSync": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "paths": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "tasks": {
          "description": "Legacy fixed-contract alias for taskIndex; canonical adapter output uses taskIndex and conflicts fail.",
          "type": "string",
          "minLength": 1
        },
        "taskIndex": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "minLength": 1
        },
        "specs": {
          "type": "string",
          "minLength": 1
        },
        "goals": {
          "type": "string",
          "minLength": 1
        },
        "milestones": {
          "type": "string",
          "minLength": 1
        },
        "runs": {
          "type": "string",
          "minLength": 1
        },
        "gateRecords": {
          "type": "string",
          "minLength": 1
        },
        "deferredRegister": {
          "type": "string",
          "minLength": 1
        },
        "mentalModels": {
          "type": "string",
          "minLength": 1
        },
        "mentalModel": {
          "description": "Legacy alias for mentalModelIndex; canonical output omits it and conflicts fail.",
          "type": "string",
          "minLength": 1
        },
        "mentalModelIndex": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "language": {
      "description": "Project adapter language policy. Runtime selection supports auto, en, and zh-CN; current localization covers supported CLI messages, not generated artifact bodies.",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "default": {
          "description": "Default language preference used after --lang and AGENT_HARNESS_LANG. Use auto, en, or zh-CN.",
          "type": "string",
          "minLength": 1
        }
      }
    },
    "communication": {
      "description": "User-facing in-turn communication policy. This shapes Harness prompts and artifacts; it does not suppress host-required commentary or filter Codex transport events.",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "commentary": {
          "description": "Commentary detail level. minimal is signal-only and is the effective default when omitted; balanced reports meaningful phase transitions; audit permits transcript-quality gate and decision updates.",
          "type": "string",
          "enum": [
            "minimal",
            "balanced",
            "audit"
          ]
        }
      }
    },
    "worktree": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "defaultPolicy": {
          "type": "string",
          "enum": [
            "local",
            "worktree",
            "ask"
          ]
        }
      }
    },
    "workMode": {
      "description": "Legacy alias for worktree; canonical output omits it and conflicts fail.",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "defaultPolicy": {
          "type": "string",
          "enum": [
            "local",
            "worktree",
            "ask"
          ]
        }
      }
    },
    "gates": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "description": "Legacy alias for requiredForCompletion; canonical output omits it and conflicts fail.",
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "requiredForCompletion": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "blocking": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        }
      }
    },
    "project": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "preflight": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "stateSync": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
